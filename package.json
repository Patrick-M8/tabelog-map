{
  "name": "tabemap",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build:data": "uv run python build_app_data.py --in-root restaurant_data --out-dir static/data",
    "build": "pnpm run build:data && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.48.1",
    "@tanstack/svelte-query": "^5.90.2",
    "@vercel/analytics": "^2.0.1",
    "idb-keyval": "^6.2.2",
    "luxon": "^3.7.2",
    "maplibre-gl": "^5.11.0",
    "svelte": "^5.39.6",
    "svelte-i18n": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@testing-library/svelte": "^5.2.8",
    "@types/node": "^24.3.3",
    "@vite-pwa/sveltekit": "^1.0.7",
    "jsdom": "^26.1.0",
    "svelte-check": "^4.3.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
